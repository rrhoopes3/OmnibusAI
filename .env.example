# Congress.gov API key (free: https://api.congress.gov/sign-up/)
CONGRESS_API_KEY=your_key_here

# ── AI Provider Selection ──────────────────────────────────
# Options: "ollama", "claude", "openai"
# Ollama = free (runs on your GPU). Cloud providers = fallback.
AI_PROVIDER=ollama

# ── Ollama (local GPU) ────────────────────────────────────
# Local:               http://localhost:11434
# Via Tailscale:       http://100.x.y.z:11434  (your machine's tailnet IP)
# Via Cloudflare Tunnel: https://ollama.omnibusai.info
OLLAMA_BASE_URL=http://localhost:11434

# Ollama native API key auth (set the same key on your Ollama server)
# Generate: openssl rand -hex 32
# OLLAMA_API_KEY=your_key_here

# Models for RTX 3090 (24GB VRAM):
#   VRAM = model weights + KV cache (grows with context length)
#   Run Ollama with: OLLAMA_FLASH_ATTENTION=1 OLLAMA_KV_CACHE_TYPE=q8_0
#
#   Model                    Weights   Max ctx (24GB, q8 KV)   Speed
#   gemma3:27b-it-q4_K_M    ~20 GB    16-24K tokens           18-25 t/s
#   qwen2.5:14b-q5_K_M      ~10 GB    32-64K tokens           40-55 t/s
#   llama3.1:8b-instruct      ~5 GB    128K tokens             80-112 t/s
OLLAMA_SMART_MODEL=gemma3:27b-it-q4_K_M
OLLAMA_FAST_MODEL=qwen2.5:14b-instruct-q5_K_M

# Context window (tokens). Must fit in VRAM alongside model weights + KV cache.
#   27B model: 16384 (safe with q8 KV cache)
#   14B model: 32768-65536
#    8B model: 131072
OLLAMA_NUM_CTX=16384

# ── Remote Access (pick one) ──────────────────────────────
#
# Option A: Tailscale (RECOMMENDED — fully private, no public exposure)
#   Setup: ./scripts/setup-tailscale.sh
#   GitHub secrets: TS_OAUTH_CLIENT_ID, TS_OAUTH_SECRET
#   OLLAMA_BASE_URL=http://100.x.y.z:11434
#
# Option B: Cloudflare Tunnel (public URL on your domain)
#   Setup: ./scripts/setup-tunnel.sh
#   OLLAMA_BASE_URL=https://ollama.omnibusai.info
#   CF_ACCESS_CLIENT_ID=your_id_here
#   CF_ACCESS_CLIENT_SECRET=your_secret_here

# ── Cloud Providers (optional fallback) ────────────────────
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# Override cloud models if needed:
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SMART_MODEL=claude-sonnet-4-6-20250514
# OPENAI_FAST_MODEL=gpt-4o-mini
# OPENAI_SMART_MODEL=gpt-4o
